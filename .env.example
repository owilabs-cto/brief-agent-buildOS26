# brief-agent-buildOS26 — env vars
#
# Copy to .env, fill in secrets, then `cargo run`. Defaults are
# laptop-local + ngrok. Production deploy (OWI-113) overrides these
# in a different .env layer.

# --- /brief orchestrator ---
APP__OPENAI__API_KEY=sk-...
APP__LINEAR_API_KEY=lin_api_...
APP__TAVILY_API_KEY=tvly-...                 # optional; DuckDuckGo HTML used as fallback
APP__BRIEF_MODEL=gpt-5.5-2026-04-23           # optional override; default snapshot pin
# APP__BRIEF_SELF_URL=http://localhost:8080   # optional; default = http://localhost:{APP__PORT}

# --- HTTP server ---
APP__PORT=8080                                # ngrok forwards 8080 → laptop

# --- Slack /brief slash command ---
APP__SLACK__BOT_TOKEN=xoxb-...
APP__SLACK__SIGNING_SECRET=...
APP__SLACK__ENABLED=true                      # default true — flip to disable

# --- OpenAI Realtime SIP (outbound voice) ---
APP__OPENAI_REALTIME__API_KEY=sk-...          # often same key as APP__OPENAI__API_KEY
APP__OPENAI_REALTIME__PROJECT_ID=proj_...     # stamped on the SIP URI
APP__OPENAI_REALTIME__BASE_URL=https://api.openai.com
APP__OPENAI_REALTIME__MODEL=gpt-realtime-2
APP__OPENAI_REALTIME__VOICE=marin
APP__OPENAI_REALTIME__WEBHOOK_SECRET=whsec_... # OpenAI Realtime webhook signing secret
APP__OPENAI_REALTIME__WEBHOOK_BASE_URL=https://your-tunnel.ngrok-free.app
APP__OPENAI_REALTIME__CALL_TIME_LIMIT_SECS=180 # Twilio backstop; default 180s
# APP__OPENAI_REALTIME__VERIFY_SIGNATURE=true # default = "WEBHOOK_SECRET non-empty"

# --- Twilio outbound ---
APP__TWILIO__ACCOUNT_SID=AC...
APP__TWILIO__AUTH_TOKEN=...
APP__TWILIO__FROM_NUMBER=+1...

# --- Destination ---
APP__OWI_FREDERIK_PHONE=+1...                 # E.164, hardcoded on the server; not passed via /brief
